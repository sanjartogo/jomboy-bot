# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_from_botfather
ADMIN_TELEGRAM_IDS=123456789,987654321  # Comma-separated, sizniki va Tulkin akaning ID si
HOKIM_TELEGRAM_ID=123456789  # Tuman hokimining Telegram ID

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-5
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# Application
NODE_ENV=development
LOG_LEVEL=info
TIMEZONE=Asia/Tashkent

# Schedules (cron format)
CRON_MORNING_REMINDER=0 9 * * *      # Har kuni 09:00
CRON_EVENING_CHECK=0 18 * * *        # Har kuni 18:00
CRON_DAILY_SUMMARY=0 19 * * *        # Har kuni 19:00 — hokimga
CRON_WEEKLY_REPORT=0 20 * * 0        # Yakshanba 20:00 — haftalik
