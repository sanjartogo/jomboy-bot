{
  "name": "jomboy-bot",
  "version": "1.0.0",
  "description": "Jomboy tumani soliq bazasini kengaytirish bo'yicha AI Telegram bot",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
